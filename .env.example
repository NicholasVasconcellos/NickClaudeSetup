# Claude Orchestrator Configuration
# Copy to .env.local and fill in values

# Claude CLI must be authenticated separately: run `claude auth login`

# Orchestrator settings
ORCHESTRATOR_MAX_CONCURRENCY=4
ORCHESTRATOR_TASK_TIMEOUT=600000
ORCHESTRATOR_OVERALL_TIMEOUT=7200000
ORCHESTRATOR_WS_PORT=3100
ORCHESTRATOR_PUSH_AFTER_MERGE=true
ORCHESTRATOR_MAIN_BRANCH=main

# Model overrides (optional)
ORCHESTRATOR_SPEC_MODEL=claude-sonnet-4-6
ORCHESTRATOR_EXECUTE_MODEL=claude-sonnet-4-6
ORCHESTRATOR_REVIEW_MODEL=claude-sonnet-4-6
ORCHESTRATOR_LEARNING_MODEL=claude-haiku-4-5-20251001

# Dashboard
DASHBOARD_PORT=3200
